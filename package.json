{
  "name": "new-motoparts",
  "version": "1.0.0",
  "private": true,
  "description": "API serverless local para intercambio de partes de motos con DynamoDB local",
  "main": "src/handlers/partes.js",
  "scripts": {
    "dev": "cross-env IS_OFFLINE=true DYNAMODB_ENDPOINT=http://localhost:8000 serverless offline --stage local",
    "offline": "npm run dev",
    "db:start": "docker compose up -d dynamodb",
    "db:stop": "docker compose down",
    "db:setup": "cross-env DYNAMODB_ENDPOINT=http://localhost:8000 node scripts/setup-dynamodb.js",
    "deploy:simulado": "node scripts/package-simulado.js",
    "deploy:simulated": "npm run deploy:simulado"
  },
  "dependencies": {
    "aws-sdk": "^2.1692.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "serverless": "^4.18.1",
    "serverless-offline": "^14.4.0"
  }
}